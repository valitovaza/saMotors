DVSA_CLIENT_ID=
DVSA_CLIENT_SECRET=
DVSA_API_KEY=
DVSA_SCOPE=https://tapi.dvsa.gov.uk/.default
DVSA_TOKEN_URL=https://login.microsoftonline.com/your-tenant-id/oauth2/v2.0/token
DVSA_API_BASE_URL=https://history.mot.api.gov.uk
# The public docs do not expose the single-registration route clearly in static HTML,
# so the backend tries these candidate paths in order.
DVSA_REGISTRATION_PATHS=/v1/trade/vehicles/registration/{registration},/v1/trade/vehicles/registration?registration={registration},/v1/trade/vehicles/registration?vrm={registration}

GOOGLE_MAPS_API_KEY=
